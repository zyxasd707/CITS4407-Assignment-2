#!/bin/bash
#
# analyse -- CITS4407 Assignment 2, Question 2
#
# Reads the cleaned trending YouTube video CSV (the format produced by the
# Q1 'clean' script) and prints five summary analyses to stdout, one per
# line, in the order required by the assignment specification.
#
# Usage:   ./analyse <input.csv>
# Example: ./analyse trending_videos_clean.csv
#
# Author:  Yuxing Zhou (24267814)
# Course:  CITS4407 S1 2026 -- Open Source Tools and Scripting

# ---------------------------------------------------------------------------
# Input
#   The cleaned CSV has a header row and six columns:
#     1 video_id  2 publish_date  3 views  4 likes  5 dislikes  6 comments_disabled
# ---------------------------------------------------------------------------
input="$1"

# ---------------------------------------------------------------------------
# Analyses
#   Each analysis is added in its own commit and prints exactly one line.
#   The output order must match the specification's sample output.
#   Where two or more videos tie, every tied video is printed.
# ---------------------------------------------------------------------------
# Analysis 1 -- most frequent video: the video_id appearing in the most rows.
# Count rows per video_id, find the highest count, then print every video_id
# that holds that count so any tie is fully reported.
awk -F',' '
    NR > 1 { count[$1]++ }
    END {
        for (id in count) if (count[id] > max) max = count[id]
        for (id in count) if (count[id] == max) print "Most frequent video, ID: " id
    }
' "$input"

# Analysis 2 -- mean of the views column, printed to two decimal places.
awk -F',' '
    NR > 1 { sum += $3; n++ }
    END { printf "Mean number of views: %.2f\n", sum / n }
' "$input"

# Analysis 3 -- video with the maximum number of dislikes.
# Track the running maximum; on a strictly greater value restart the output
# list, on an equal value append to it, so every tied video_id is printed.
awk -F',' '
    NR > 1 {
        dislikes = $5 + 0
        if (dislikes > max) { max = dislikes; out = "Max dislikes video, ID: " $1 }
        else if (dislikes == max) { out = out "\n" "Max dislikes video, ID: " $1 }
    }
    END { print out }
' "$input"
# Analysis 4 -- video with the highest engagement rate, (likes+dislikes)/views.
# Same running-extreme + tie-list pattern as Analysis 3. The "$3 > 0" guard
# skips any row with zero views, which would otherwise divide by zero.
awk -F',' '
    NR > 1 && $3 + 0 > 0 {
        rate = ($4 + $5) / $3
        if (!started)         { started = 1; max = rate; out = "Highest engagement rate video, ID: " $1 ", dated: " $2 }
        else if (rate > max)  { max = rate; out = "Highest engagement rate video, ID: " $1 ", dated: " $2 }
        else if (rate == max) { out = out "\n" "Highest engagement rate video, ID: " $1 ", dated: " $2 }
    }
    END { print out }
' "$input"

# Analysis 5 -- video with the least (most negative) net sentiment rate,
# (likes-dislikes)/views.
# Note: the printed line has a space before the comma after the ID
# ("ID: <id> , dated:"). This deliberately reproduces the assignment's
# sample output, which is formatted that way for this line only.
awk -F',' '
    NR > 1 && $3 + 0 > 0 {
        rate = ($4 - $5) / $3
        if (!started)         { started = 1; min = rate; out = "Least sentiment rate video, ID: " $1 " , dated: " $2 }
        else if (rate < min)  { min = rate; out = "Least sentiment rate video, ID: " $1 " , dated: " $2 }
        else if (rate == min) { out = out "\n" "Least sentiment rate video, ID: " $1 " , dated: " $2 }
    }
    END { print out }
' "$input"
