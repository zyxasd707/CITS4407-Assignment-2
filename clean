#!/bin/bash
#
# clean -- CITS4407 Assignment 2, Question 1
#
# Performs error checks on a CSV input, then cleans the trending YouTube
# video data: drops the redundant ratings_disabled column, removes invalid
# rows, de-duplicates, and strips the time component from publish_date.
#
# Usage:   ./clean <input.csv>
# Example: ./clean trending_videos_unclean.csv > trending_videos_clean.csv
#
# Author:  Yuxing Zhou (24267814)
# Course:  CITS4407 S1 2026 -- Open Source Tools and Scripting

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
EXPECTED_COLUMNS=7

# ---------------------------------------------------------------------------
# Argument capture
# ---------------------------------------------------------------------------
input="$1"

# ---------------------------------------------------------------------------
# Stage 1: Error checks
#   Each check echoes the required ERROR message and exits with status 1.
# ---------------------------------------------------------------------------
# Error check #1: no input argument provided
if [ -z "$input" ]; then
    echo "ERROR: No input CSV file provided"
    exit 1
fi

# Error check #2: input file not found in the current directory
if [ ! -f "$input" ]; then
    echo "ERROR: Input file not found in the current directory"
    exit 1
fi

# Error check #3: input file does not have a .csv extension
if [[ "$input" != *.csv ]]; then
    echo "ERROR: Input file expected in a CSV format"
    exit 1
fi

# Error check #4: input file is empty
if [ ! -s "$input" ]; then
    echo "ERROR: Empty file provided"
    exit 1
fi

# Error check #5: header does not have $EXPECTED_COLUMNS columns
header_columns=$(awk -F',' 'NR==1 {print NF; exit}' "$input")
if [ "$header_columns" -ne "$EXPECTED_COLUMNS" ]; then
    echo "ERROR: Expected 7 columns in the input"
    exit 1
fi


# ---------------------------------------------------------------------------
# Stage 2: Data cleaning
#   Each step operates on the previous step's output; final result goes to
#   stdout. The pipeline avoids leaving temporary files on disk.
# ---------------------------------------------------------------------------
# Cleaning pipeline (extended commit-by-commit; listed in pipeline order):
#   Stage A (commit #11): drop invalid rows -- keep a row only if it has
#                         exactly 7 columns (matching the header) and a
#                         non-empty video_id.
#   Stage B (commit #9):  drop the redundant ratings_disabled column.
#   Stage C (commit #10): strip the time portion from publish_date so only
#                         YYYY-MM-DD remains.
# Notes:
#  - Stage A runs first, on the raw input, on purpose: once cut truncates
#    each row to 6 fields an NF test can no longer detect rows that began
#    with the wrong column count, so NF==7 must be checked before cut.
#  - NR==1 always keeps the header row.
#  - The spec guarantees column order is fixed, so keeping fields 1-6 with
#    cut is equivalent to deleting the named ratings_disabled column.
#  - The sed regex T[0-9:.][0-9:.]*Z uses BRE-style "one or more" (an
#    initial class followed by a starred class), mirroring the floating
#    point pattern taught in L10 Page 22 ([0-9][0-9]*). It matches the
#    ISO-8601 time suffix unique to publish_date; no other field contains
#    digits/colons between a T and Z, so the substitution is field-safe.
awk -F',' 'NR==1 || (NF==7 && $1!="")' "$input" | cut -d',' -f1-6 | sed 's/T[0-9:.][0-9:.]*Z//'
# TODO (Commit #12): Drop rows with likes==0 or dislikes==0, then de-duplicate

# ---------------------------------------------------------------------------
# Stage 3: Output
#   The cleaned CSV is written to stdout (redirect when calling, e.g.
#   ./clean input.csv > clean_output.csv).
# ---------------------------------------------------------------------------
# (Implemented inline as part of the cleaning pipeline above.)
