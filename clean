#!/bin/bash
#
# clean -- CITS4407 Assignment 2, Question 1
#
# Performs error checks on a CSV input, then cleans the trending YouTube
# video data: drops the redundant ratings_disabled column, removes invalid
# rows, de-duplicates, and strips the time component from publish_date.
#
# Usage:   ./clean <input.csv>
# Example: ./clean trending_videos_unclean.csv > trending_videos_clean.csv
#
# Author:  Yuxing Zhou (24267814)
# Course:  CITS4407 S1 2026 -- Open Source Tools and Scripting

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
EXPECTED_COLUMNS=7

# ---------------------------------------------------------------------------
# Argument capture
# ---------------------------------------------------------------------------
input="$1"

# ---------------------------------------------------------------------------
# Stage 1: Error checks
#   Each check echoes the required ERROR message and exits with status 1.
# ---------------------------------------------------------------------------
# Error check #1: no input argument provided
if [ -z "$input" ]; then
    echo "ERROR: No input CSV file provided"
    exit 1
fi

# Error check #2: input file not found in the current directory
if [ ! -f "$input" ]; then
    echo "ERROR: Input file not found in the current directory"
    exit 1
fi

# Error check #3: input file does not have a .csv extension
if [[ "$input" != *.csv ]]; then
    echo "ERROR: Input file expected in a CSV format"
    exit 1
fi

# Error check #4: input file is empty
if [ ! -s "$input" ]; then
    echo "ERROR: Empty file provided"
    exit 1
fi

